# ═══════════════════════════════════════════════════════
# 🛡️ ORGANIZA DASHBOARD — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════
# NUNCA commite o arquivo .env real no Git!
# Copie este arquivo como .env e preencha com seus valores reais.

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster0.xxxxx.mongodb.net/taskmanager?appName=Cluster0

# JWT Secret — Use uma chave forte e aleatória (mínimo 32 caracteres)
JWT_SECRET=sua_chave_secreta_forte_aqui_minimo_32_chars

# Porta do servidor
PORT=5000

# Credenciais do Gmail para recuperação de senha
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app_gmail

# Ambiente (development ou production)
NODE_ENV=development
